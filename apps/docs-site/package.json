{
  "name": "docs-site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vitepress dev docs --port 3000",
    "build": "vitepress build docs",
    "preview": "vitepress preview docs --port 4173",
    "docs:dev": "portless run --name docs.oore vitepress dev docs",
    "docs:dev:legacy": "vitepress dev docs --port 4173",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --port 4173",
    "test": "vitest run --passWithNoTests",
    "lint": "oxlint .",
    "format": "prettier",
    "check": "prettier --check . && oxlint ."
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "vitepress-openapi": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "prettier": "^3.9.5",
    "typescript": "7.0.2",
    "vite": "^8.1.4",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.10",
    "vue": "^3.5.39"
  }
}
