{
  "name": "web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless run --name web.oore --app-port 3000 vite --port 3000",
    "dev:legacy": "vite --port 3000",
    "build": "vite build && tsc",
    "bundle:check": "node tools/check-bundle-budget.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "playwright test",
    "lint": "oxlint . && bun run lint:effects",
    "lint:effects": "! grep -RInE '\\b(React\\.)?useEffect\\b' src --include='*.ts' --include='*.tsx' --exclude='use-mount-effect.ts' --exclude='use-breadcrumb-label.ts' --exclude='use-auto-scroll.ts' --exclude='use-build-notification.ts' --exclude='use-session-countdown.ts' --exclude='use-log-stream.ts' --exclude='use-index-auth-guard.ts' --exclude='use-trusted-proxy-auto-login.ts' --exclude='use-setup-route-transitions.ts' --exclude='use-window-event.ts' --exclude='use-repository-avatar-url.ts' --exclude='use-debounced-callback.ts' --exclude='use-page-clamp.ts'",
    "format": "prettier",
    "check": "prettier --write . && oxlint --fix . && bun run lint:effects"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@mswjs/interceptors": "^0.41.9",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.6",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "cnfast": "^0.0.8",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-markdown": "^10.1.0",
    "sonner": "^2.0.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/devtools-vite": "^0.8.1",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "msw": "^2.15.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "prettier": "^3.9.5",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "web-vitals": "^5.3.0"
  }
}
