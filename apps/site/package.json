{
  "name": "site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bash ../../tools/sync-install-scripts.sh && portless run --name oore vite",
    "dev:legacy": "bash ../../tools/sync-install-scripts.sh && vite --port 3002",
