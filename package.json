{
  "name": "oore-build",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "cd apps/web && bun run dev",
    "dev:docs": "cd apps/docs-site && bun run docs:dev",
    "dev:site": "cd apps/site && bun run dev",
    "build:web": "cd apps/web && bun run build",
    "bundle:check": "cd apps/web && bun run bundle:check",
    "build:docs": "cd apps/docs-site && bun run docs:build",
    "build:site": "cd apps/site && bun run build",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --type-aware .",
    "lint:fix": "oxlint --type-aware --fix .",
    "check": "bun run format:check && bun run lint"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "oxfmt": "0.59.0",
    "oxlint": "1.73.0",
    "oxlint-tailwindcss": "^1.3.5",
    "oxlint-tsgolint": "0.24.0",
    "wrangler": "4.110.0"
  }
}
